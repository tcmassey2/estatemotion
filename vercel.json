{
  "cleanUrls": true,
  "trailingSlash": false,
  "buildCommand": "node scripts/verify-static-deploy.mjs && cd webapp && npm install --no-audit --no-fund && npm run build",
  "outputDirectory": ".",
  "crons": [
    {
      "path": "/api/cron/trial-reminders",
      "schedule": "0 14 * * *"
    }
  ],
  "rewrites": [
    { "source": "/demo", "destination": "/app/index.html" },
    { "source": "/demo/:path*", "destination": "/app/index.html" },
    { "source": "/beta", "destination": "/app/index.html" },
    { "source": "/beta/:path*", "destination": "/app/index.html" },
    { "source": "/waitlist", "destination": "/app/index.html" },
    { "source": "/waitlist/:path*", "destination": "/app/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/app/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
